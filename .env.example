# ИИ-Юрист — настройки окружения
# Скопируйте этот файл: cp .env.example .env
# И заполните нужные значения.

# === Вариант 1: OpenRouter (рекомендуется, дешевле) ===
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-ваш-ключ-здесь
# Модель (по умолчанию Claude Sonnet):
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# === Вариант 2: Anthropic напрямую ===
# Получить ключ: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-ваш-ключ-здесь
# CLAUDE_MODEL=claude-sonnet-4-20250514

# === Telegram-бот (Фаза 2) ===
# Создать бота: @BotFather в Telegram
TELEGRAM_BOT_TOKEN=ваш-токен-здесь
# Ваш Telegram user ID (узнать: @userinfobot в Telegram)
# Нужен для доступа к админ-командам (/stats, /list, /rebuild, загрузка файлов)
ADMIN_USER_ID=ваш-user-id-здесь

# === Neo4j (Фаза 3, опционально) ===
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
